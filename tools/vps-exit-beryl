#!/bin/bash
# 切换 VPS 走 Beryl AX 出口（住宅 IP）
# 先检查 Beryl AX 是否在线，避免 VPS 断网
set -e

echo "🔍 检查 Beryl AX 是否在线..."
if ! tailscale status 2>/dev/null | grep gl-mt3000 | grep -qv "offline"; then
    echo "❌ Beryl AX (gl-mt3000) 在 Tailscale 中离线，拒绝切换"
    exit 1
fi

if ! ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=no root@gl-mt3000 "echo OK" &>/dev/null; then
    echo "❌ Beryl AX SSH 不可达，拒绝切换"
    exit 1
fi

echo "✅ Beryl AX 在线，执行切换..."
sudo tailscale set --exit-node=gl-mt3000
echo "✅ VPS 出口 → Beryl AX (gl-mt3000)"
sleep 2
curl -sI https://order.chownow.com 2>/dev/null | head -1 || echo "⚠ 连通性测试未返回（可能需等几秒）"
